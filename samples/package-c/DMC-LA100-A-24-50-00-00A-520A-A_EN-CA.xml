  <content>
    <procedure>
      <preliminaryRqmts>
        <reqCondGroup>
          <reqCond>Aircraft electrical power is OFF and the battery switch is
          tagged out.</reqCond>
        </reqCondGroup>
        <reqSupportEquips>
          <supportEquipDescr>Insulated terminal wrench</supportEquipDescr>
        </reqSupportEquips>
        <reqSafety>
          <safetyRqmts>
            <warning>
              <warningAndCautionPara>Battery terminals can supply high current
              even with aircraft power off. Disconnect the negative terminal
              first and keep tools clear of the positive terminal.</warningAndCautionPara>
            </warning>
          </safetyRqmts>
        </reqSafety>
      </preliminaryRqmts>
      <mainProcedure>
        <proceduralStep>
          <para>Open the battery compartment access panel.</para>
        </proceduralStep>
        <proceduralStep>
          <para>Disconnect the negative terminal, then the positive terminal.
          Cap both terminals.</para>
        </proceduralStep>
        <proceduralStep>
          <!-- Day 12 DELIBERATE synthetic figure-vs-text conflict (Class B trap,
               docs/specs/day12.md Decision 3b): the battery-housing part number
               here (LA-24-9002-3) intentionally differs from figure
               ICN-LA100-24-002-01 hotspot 02 (LA-24-5002-6). Synthetic (INV-1);
               documented so it is not mistaken for a defect. -->
          <para>Release the hold-down clamps and lift the battery housing (part
          LA-24-9002-3) out of the tray.</para>
        </proceduralStep>
      </mainProcedure>
      <closeRqmts>
        <reqCondGroup>
          <reqCond>Battery tray is clean and the access panel is closed.</reqCond>
        </reqCondGroup>
      </closeRqmts>
    </procedure>
    <figure>
      <title>Main battery installation</title>
      <graphic infoEntityIdent="ICN-LA100-24-002-01"/>
