# MiniMax chat config (Day 5 answer generation). Values live only in your
# local .env (git-ignored); the loader reads the REPO-ROOT .env only, accepts
# only MINIMAX_* keys, and requires https (src/learnarken/config.py).
MINIMAX_API_URL=https://<your-proxy-host>/v1
MINIMAX_MODEL_NAME=MiniMax-M3
MINIMAX_API_KEY=<secret>
MINIMAX_API_PROXY_TOKEN=<secret>
NEO4J_USER=neo4j
NEO4J_PASSWORD=learnarken
